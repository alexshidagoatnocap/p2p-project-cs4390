{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Debug Tracker",
            "type": "gdb",
            "request": "launch",
            "program": "${workspaceFolder}/build_debug/tracker/tracker_app",
            "stopAtEntry": true,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "externalConsole": true
        },
    ]
}
