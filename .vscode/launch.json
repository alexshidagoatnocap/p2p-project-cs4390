{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Debug Tracker",
            "type": "gdb",
            "request": "launch",
            "program": "${workspaceFolder}/build/tracker/tracker_app",
            "stopAtEntry": true,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "externalConsole": true
        },
        {
            "name": "(gdb) Debug Peer",
            "type": "gdb",
            "request": "launch",
            "program": "${workspaceFolder}/build/peer/peer_app",
            "stopAtEntry": true,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "externalConsole": true
        }
    ]
}
